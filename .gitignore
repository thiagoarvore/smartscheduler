# ============================================================================
# SmartSchedule (Grade Certa) — .gitignore
# ============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
eggs/
.eggs/
develop-eggs/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/

# ---------------------------------------------------------------------------
# Poetry
# ---------------------------------------------------------------------------
poetry.lock

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
db.sqlite3
db.sqlite3-journal
*.sqlite3
media/
staticfiles/

# ---------------------------------------------------------------------------
# Environment / Secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
.classpath
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Testing / Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.cover
.noseids
.pytest_worker_*/

# ---------------------------------------------------------------------------
# Docker (local overrides)
# ---------------------------------------------------------------------------
docker-compose.override.yml

# ---------------------------------------------------------------------------
# Documentation builds
# ---------------------------------------------------------------------------
docs/_build/
docs/.doctrees/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# Large / generated assets
# ---------------------------------------------------------------------------
designs/identity/grade-certa-identity-landing-pages.zip

# ---------------------------------------------------------------------------
# Temporary / scratch
# ---------------------------------------------------------------------------
.codex
plan.md
.plan/
*.tmp
*.bak
*.orig

# ---------------------------------------------------------------------------
# Node (if ever used for frontend tooling)
# ---------------------------------------------------------------------------
node_modules/