# Grade Certa — Environment Variables
# Copie este arquivo para .env e ajuste os valores
#
# Referência completa: README.md → seção "Variáveis de ambiente"

# ── Ambiente ──────────────────────────────────────────────────────────────────
# Controla DEBUG, cooldown do solver e bootstrap do tenant demo automaticamente.
# Valores: local | dev | test | staging | production
ENVIRONMENT=local

# ── Django ────────────────────────────────────────────────────────────────────
# Em produção, gere uma chave secreta real:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-smartschedule-dev-key-change-in-production

# Ativo por padrão em local/dev. Em staging/production, defina explicitamente:
# DEBUG=False

# Hosts permitidos (comma-separated). Em produção, inclua o domínio real:
# ALLOWED_HOSTS=grade-certa.com.br,.grade-certa.com.br
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# ── Banco de dados (PostgreSQL) ──────────────────────────────────────────────
# Necessário para rodar com django-tenants (produção e desenvolvimento local).
# Testes (settings_test.py) usam SQLite in-memory e NÃO precisam destas vars.
DB_NAME=smartschedule
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# ── Tenant demo (bootstrap) ──────────────────────────────────────────────────
# Ativo por padrão em local/dev. Desabilite em produção.
DEMO_TENANT_ENABLED=True
DEMO_TENANT_NAME=Colegio Objetivo
DEMO_TENANT_SCHEMA_NAME=colegioobjetivo
DEMO_TENANT_DOMAIN=localhost

# ── Solver (Grade Certa) ─────────────────────────────────────────────────────
# Cooldown: 1 execução por hora por SchoolYear em produção.
# Desabilitado automaticamente em local/dev/test (controlado por ENVIRONMENT).
# GRADE_CERTA_COOLDOWN_DISABLED=True

# ── Celery / Redis (quando ativo) ────────────────────────────────────────────
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0