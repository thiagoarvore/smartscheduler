# Grade Certa - Environment Variables
# Copy this file to .env and fill in the values

ENVIRONMENT=local
DEBUG=True
SECRET_KEY=django-insecure-smartschedule-dev-key-change-in-production

# Database (used when ENVIRONMENT is not "local")
DB_NAME=smartschedule
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1
